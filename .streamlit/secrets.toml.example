# Paste these key-value pairs into the Streamlit Community Cloud
# "Secrets" panel (App settings → Secrets) — do NOT commit a filled-in copy.
#
# For Gmail: create an App Password at myaccount.google.com/apppasswords
# For Zoho / other providers: use their SMTP credentials.

SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "your.address@gmail.com"
SMTP_PASS = "your_app_password_here"
FROM_ADDRESS = "diagnostics@techkative.com"
TECHKATIVE_INBOX = "info@techkative.com"
